<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@yield('title', 'bun-queue')</title>
  <script src="/bq-utils.js"></script>
  @stack('head')
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

    /* Sidebar collapsed state overrides */
    .sidebar.collapsed { width: 56px !important; }
    .sidebar.collapsed .sidebar-brand-text { display: none; }
    .sidebar.collapsed .sidebar-toggle-btn { margin-left: auto; margin-right: auto; }
    .sidebar.collapsed .nav-label { opacity: 0; height: 0; padding: 0; overflow: hidden; }
    .sidebar.collapsed .nav-item-text { display: none; }
    .sidebar.collapsed ~ .main-wrapper { margin-left: 56px !important; }

    /* Override router inline styles on nav items — sidebar manages its own active state */
    #sidebar .nav-item { background: unset !important; color: unset !important; font-weight: unset !important; }

    /* Active state */
    #sidebar .nav-item.active { background: #6366f1 !important; color: white !important; }
    #sidebar .nav-item.active svg { opacity: 1; }
  </style>
</head>
<body class="bg-[#0a0a0f] text-zinc-50 leading-relaxed min-h-screen @yield('body-class')">
  @include('../partials/sidebar')

  <!-- Main Content -->
  <div class="main-wrapper transition-all duration-200 ease-in-out @yield('main-class', 'min-h-screen')" id="main-wrapper" ref="main-wrapper" style="margin-left: 240px;">
    @stack('styles')
    @stack('scripts')
    <div id="page-content" x-cloak>
      @yield('content')
    </div>
  </div>

  <script>window.STX_ROUTER_OPTIONS = { container: '#main-wrapper' }</script>

  <script client>
    const collapsed = useLocalStorage<boolean>('sidebar-collapsed', false)
    const currentPath = state<string>(location.pathname)

    function toggle(): void {
      collapsed.set(!collapsed())
    }

    function isActive(href: string): boolean {
      const cur: string = currentPath()
      if (href === '/') return cur === '/'
      return cur === href || cur.startsWith(href + '/')
    }

    function updateActiveLinks(): void {
      const cur: string = currentPath()
      const links: HTMLElement | null = useRef<HTMLElement>('sidebar-nav').current
      if (!links) return
      links.querySelectorAll('.nav-item').forEach((a: Element) => {
        const href: string = a.getAttribute('href') || ''
        const active: boolean = href === '/' ? cur === '/' : (cur === href || cur.startsWith(href + '/'))
        if (active) a.classList.add('active')
        else a.classList.remove('active')
      })
    }

    onMount((): void => { updateActiveLinks() })

    useEventListener('stx:navigate', (): void => {
      currentPath.set(location.pathname)
      updateActiveLinks()
    })

    useEventListener('popstate', (): void => {
      currentPath.set(location.pathname)
      updateActiveLinks()
    })
  </script>

</body>
</html>
